// NetSuite-Clone - Multi-tenant ERP Schema
// Prisma 7+ — URL configured in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TENANTS
// ─────────────────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Datos fiscales y bancarios
  taxId           String?
  bankAccount     String?
  bankAccountType String?  @default("Savings")

  /// ── Trial / Subscription ────────────────────────────────────────────
  /// Estado de suscripción: trial | active | expired | cancelled | suspended
  subscriptionStatus   String   @default("trial")
  /// Vencimiento del período de prueba (now + 5 days on register)
  trialEndsAt          DateTime?
  /// Plan activo: monthly | annual | enterprise
  subscriptionPlan     String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?

  /// ── Billing cycle ────────────────────────────────────────────────────
  billingStartDate DateTime  @default(now())
  nextBillingDate  DateTime  @default(now())
  billingEmail     String?

  users              User[]
  roles              Role[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  inventoryItems     InventoryItem[]
  stockTransactions  StockTransaction[]
  customers          Customer[]
  invoices           Invoice[]
  projects           Project[]
  employees          Employee[]
  payrollPeriods     PayrollPeriod[]
  apuChapters        ApuChapter[]
  apuItems           ApuItem[]
  officialBudgets    OfficialBudget[]
  certificates       ProjectCertificate[]
  liquidations       ProjectLiquidation[]
  vendors            Vendor[]
  purchaseInvoices   PurchaseInvoice[]
  vendorPayments     VendorPayment[]
  cashReceipts       CashReceipt[]
  cashDisbursements  CashDisbursement[]
  pettyCashFunds     PettyCashFund[]
  taxObligations     TaxObligation[]
  billingInvoices    BillingInvoice[]

  @@map("tenants")
}

// ─────────────────────────────────────────────
// ROLES
// ─────────────────────────────────────────────
model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  tenantId     String
  roleId       String?
  email        String
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  /// Permisos adicionales específicos de este usuario
  /// (se suman a los del rol — pueden sobrescribir o ampliar)
  customPermissions Json @default("[]")

  /// Super-admin del sistema: acceso ilimitado a todos los tenants
  isSuperAdmin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role?  @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@map("users")
}

// ─────────────────────────────────────────────
// ACCOUNTS (Chart of Accounts)
// ─────────────────────────────────────────────
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id          String      @id @default(uuid())
  tenantId    String
  code        String
  name        String
  type        AccountType
  parentId    String?
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// JOURNAL ENTRIES
// ─────────────────────────────────────────────
enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalEntry {
  id          String             @id @default(uuid())
  tenantId    String
  reference   String
  description String?
  date        DateTime
  status      JournalEntryStatus @default(DRAFT)
  postedAt    DateTime?
  createdBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines   JournalLine[]
  invoice Invoice?      // set when entry is auto-generated by an Invoice issue

  // Accounting module back-relations
  purchaseInvoice  PurchaseInvoice?
  vendorPayment    VendorPayment?    @relation("VendorPaymentJournal")
  cashReceipt      CashReceipt?
  cashDisbursement CashDisbursement?
  taxObligation    TaxObligation?

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@map("journal_entries")
}

model JournalLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal @default(0) @db.Decimal(18, 4)
  credit         Decimal @default(0) @db.Decimal(18, 4)
  order          Int     @default(0)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ─────────────────────────────────────────────
// INVENTORY ITEMS
// ─────────────────────────────────────────────
enum InventoryItemType {
  PRODUCT
  SERVICE
  RAW_MATERIAL
  FINISHED_GOOD
}

model InventoryItem {
  id             String            @id @default(uuid())
  tenantId       String
  sku            String
  name           String
  description    String?
  type           InventoryItemType @default(PRODUCT)
  unitOfMeasure  String            @default("UNIT")
  /// Weighted Average Cost — updated on every ENTRY transaction
  costPrice      Decimal           @default(0) @db.Decimal(18, 4)
  sellingPrice   Decimal           @default(0) @db.Decimal(18, 4)
  quantityOnHand Decimal           @default(0) @db.Decimal(18, 4)
  reorderPoint   Decimal           @default(0) @db.Decimal(18, 4)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockTransactions StockTransaction[]
  invoiceLines      InvoiceLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@map("inventory_items")
}

// ─────────────────────────────────────────────
// STOCK TRANSACTIONS
// ─────────────────────────────────────────────
enum StockTransactionType {
  /// Goods received: increases quantity and recalculates WAC
  ENTRY
  /// Goods dispatched: decreases quantity; WAC is unchanged
  EXIT
}

model StockTransaction {
  id              String               @id @default(uuid())
  tenantId        String
  inventoryItemId String
  type            StockTransactionType
  quantity        Decimal              @db.Decimal(18, 4)
  /// Per-unit cost: entry price for ENTRY, current WAC for EXIT
  unitCost        Decimal              @db.Decimal(18, 4)
  /// quantity * unitCost
  totalCost       Decimal              @db.Decimal(18, 4)

  /// Audit snapshots: state of the item BEFORE this transaction
  quantityBefore Decimal @db.Decimal(18, 4)
  wacBefore      Decimal @db.Decimal(18, 4)

  /// State of the item AFTER this transaction
  quantityAfter  Decimal @db.Decimal(18, 4)
  wacAfter       Decimal @db.Decimal(18, 4)

  reference  String?
  notes      String?
  createdBy  String?
  createdAt  DateTime @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([tenantId])
  @@index([tenantId, inventoryItemId])
  @@index([tenantId, createdAt])
  @@map("stock_transactions")
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────
model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("customers")
}

// ─────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────
enum InvoiceStatus {
  DRAFT    // Being built
  ISSUED   // Emitted: stock reduced + journal entry created + auto-posted
  PAID     // Payment fully received
  VOIDED   // Cancelled (cannot be re-issued)
}

model Invoice {
  id         String        @id @default(uuid())
  tenantId   String
  customerId String
  number     String
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime?
  dueDate    DateTime?

  /// Pre-computed totals (persisted for reporting performance)
  subtotal   Decimal  @default(0) @db.Decimal(18, 4)
  taxRate    Decimal  @default(0) @db.Decimal(7, 6)  // e.g. 0.190000 = 19 %
  taxAmount  Decimal  @default(0) @db.Decimal(18, 4)
  total      Decimal  @default(0) @db.Decimal(18, 4) // subtotal + taxAmount

  notes String?

  /// Accounts used when the journal entry was generated
  arAccountId       String?
  revenueAccountId  String?
  taxAccountId      String?

  /// Back-link to the auto-generated journal entry (set on ISSUE)
  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id])
  lines        InvoiceLine[]
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@map("invoices")
}

model InvoiceLine {
  id              String  @id @default(uuid())
  invoiceId       String
  inventoryItemId String?
  description     String
  quantity        Decimal @db.Decimal(18, 4)
  unitPrice       Decimal @db.Decimal(18, 4)
  subtotal        Decimal @db.Decimal(18, 4) // quantity × unitPrice

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ─────────────────────────────────────────────
// PROJECTS (Ingeniería Civil)
// ─────────────────────────────────────────────
enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id          String        @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  clientName  String?
  location    String?

  /// Contract value (base, before AIU)
  contractValue Decimal @default(0) @db.Decimal(18, 2)

  /// AIU percentages (stored as decimals, e.g. 0.10 = 10%)
  adminPct   Decimal @default(0) @db.Decimal(7, 6) // Administración
  riskPct    Decimal @default(0) @db.Decimal(7, 6) // Imprevistos
  profitPct  Decimal @default(0) @db.Decimal(7, 6) // Utilidad

  /// Computed totals (persisted for reporting)
  adminAmount   Decimal @default(0) @db.Decimal(18, 2)
  riskAmount    Decimal @default(0) @db.Decimal(18, 2)
  profitAmount  Decimal @default(0) @db.Decimal(18, 2)
  aiuAmount     Decimal @default(0) @db.Decimal(18, 2) // sum of the three
  totalValue    Decimal @default(0) @db.Decimal(18, 2) // contractValue + aiuAmount

  startDate    DateTime?
  endDate      DateTime?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phases  ProjectPhase[]
  budgets ProjectBudget[]
  aiuBreakdowns     AiuBreakdown[]
  officialBudgets   OfficialBudget[]
  certificates      ProjectCertificate[]
  liquidation       ProjectLiquidation?
  disbursements     CashDisbursement[]
  pettyCashFunds    PettyCashFund[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("projects")
}

// ─────────────────────────────────────────────
// PROJECT PHASES
// ─────────────────────────────────────────────
model ProjectPhase {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  order       Int      @default(0)
  /// Planned percentage of total work (0-100)
  plannedPct  Decimal  @default(0) @db.Decimal(5, 2)
  /// Actual completion percentage (0-100)
  actualPct   Decimal  @default(0) @db.Decimal(5, 2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_phases")
}

// ─────────────────────────────────────────────
// PROJECT BUDGET LINES (Análisis de Precios Unitarios)
// ─────────────────────────────────────────────
enum BudgetCategory {
  MATERIALS    // Materiales
  LABOR        // Mano de obra
  EQUIPMENT    // Equipos
  SUBCONTRACT  // Subcontratos
  OTHER        // Otros directos
}

model ProjectBudget {
  id          String         @id @default(uuid())
  projectId   String
  category    BudgetCategory
  description String
  unit        String         @default("GL") // Unidad de medida
  quantity    Decimal        @db.Decimal(18, 4)
  unitCost    Decimal        @db.Decimal(18, 2)
  totalCost   Decimal        @db.Decimal(18, 2) // quantity × unitCost
  /// Actual spent (updated via progress entries)
  actualCost  Decimal        @default(0) @db.Decimal(18, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, category])
  @@map("project_budgets")
}

// ─────────────────────────────────────────────
// AIU BREAKDOWN (audit trail per contract)
// ─────────────────────────────────────────────
model AiuBreakdown {
  id          String   @id @default(uuid())
  projectId   String
  version     Int      @default(1)
  description String?

  contractValue Decimal @db.Decimal(18, 2)
  adminPct      Decimal @db.Decimal(7, 6)
  riskPct       Decimal @db.Decimal(7, 6)
  profitPct     Decimal @db.Decimal(7, 6)
  adminAmount   Decimal @db.Decimal(18, 2)
  riskAmount    Decimal @db.Decimal(18, 2)
  profitAmount  Decimal @db.Decimal(18, 2)
  aiuAmount     Decimal @db.Decimal(18, 2)
  totalValue    Decimal @db.Decimal(18, 2)

  createdBy String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("aiu_breakdowns")
}

// ═══════════════════════════════════════════════════════════════
// NÓMINA — Colombian Payroll + CST
// ═══════════════════════════════════════════════════════════════

enum ContractType {
  INDEFINIDO       // Contrato a término indefinido
  FIJO             // Contrato a término fijo
  OBRA_LABOR       // Contrato por obra o labor
  APRENDIZAJE      // Contrato de aprendizaje SENA
}

enum ArlRiskLevel {
  I   // 0.522%
  II  // 1.044%
  III // 2.436%
  IV  // 4.350%
  V   // 6.960%
}

model Employee {
  id           String       @id @default(uuid())
  tenantId     String
  code         String
  firstName    String
  lastName     String
  document     String       // Cédula de ciudadanía
  position     String
  department   String?
  contractType ContractType @default(INDEFINIDO)

  /// Salario mensual base (COP)
  baseSalary        Decimal @db.Decimal(18, 2)
  /// Auxilio de transporte — true si salario ≤ 2 SMMLV
  transportAllowance Boolean @default(false)

  riskLevel ArlRiskLevel @default(I)

  eps              String? // Nombre EPS
  pensionFund      String? // Fondo de pensiones
  compensationBox  String? // Caja de compensación

  /// Información bancaria
  bankAccount      String?
  bankAccountType  String?      @default("Savings")
  bankName         String?      @default("Bancolombia")

  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollPeriods PayrollPeriod[]

  @@unique([tenantId, code])
  @@unique([tenantId, document])
  @@index([tenantId])
  @@map("employees")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model PayrollPeriod {
  id         String        @id @default(uuid())
  tenantId   String
  employeeId String
  year       Int
  month      Int           // 1-12
  /// 1 = primera quincena, 2 = segunda quincena, 0 = mensual completo
  fortnight  Int           @default(0)
  startDate  DateTime
  endDate    DateTime
  status     PayrollStatus @default(DRAFT)

  // ── Devengado ────────────────────────────────────────────────
  baseSalary            Decimal @default(0) @db.Decimal(18, 2)
  transportAllowance    Decimal @default(0) @db.Decimal(18, 2) // $200.000 2025
  overtimeDayPct25      Decimal @default(0) @db.Decimal(18, 2) // HED 25%
  overtimeNightPct75    Decimal @default(0) @db.Decimal(18, 2) // HEN 75%
  overtimeHolidayPct75  Decimal @default(0) @db.Decimal(18, 2) // HEDF 75%
  overtimeHolidayPct100 Decimal @default(0) @db.Decimal(18, 2) // HEDFC 100%
  bonuses               Decimal @default(0) @db.Decimal(18, 2) // Otros devengos
  totalEarned           Decimal @default(0) @db.Decimal(18, 2)

  // ── Deducciones empleado ──────────────────────────────────────
  healthEmployee    Decimal @default(0) @db.Decimal(18, 2) // 4% EPS
  pensionEmployee   Decimal @default(0) @db.Decimal(18, 2) // 4% Pensión
  incomeTax         Decimal @default(0) @db.Decimal(18, 2) // Retención fuente
  otherDeductions   Decimal @default(0) @db.Decimal(18, 2)
  totalDeductions   Decimal @default(0) @db.Decimal(18, 2)
  netPay            Decimal @default(0) @db.Decimal(18, 2)

  // ── Prestaciones sociales (acumuladas del período) ────────────
  prima                Decimal @default(0) @db.Decimal(18, 2) // 8.33%/mes
  cesantias            Decimal @default(0) @db.Decimal(18, 2) // 8.33%/mes
  interesesCesantias   Decimal @default(0) @db.Decimal(18, 2) // 1%/mes (12%/año)
  vacaciones           Decimal @default(0) @db.Decimal(18, 2) // 4.17%/mes

  // ── Aportes patronales ────────────────────────────────────────
  healthEmployer       Decimal @default(0) @db.Decimal(18, 2) // 8.5%
  pensionEmployer      Decimal @default(0) @db.Decimal(18, 2) // 12%
  arl                  Decimal @default(0) @db.Decimal(18, 2) // risk-based
  sena                 Decimal @default(0) @db.Decimal(18, 2) // 2%
  icbf                 Decimal @default(0) @db.Decimal(18, 2) // 3%
  compensationBox      Decimal @default(0) @db.Decimal(18, 2) // 4%
  totalEmployerContrib Decimal @default(0) @db.Decimal(18, 2)

  /// Total costo del trabajador = netPay + totalEmployerContrib + prestaciones
  totalLaborCost Decimal @default(0) @db.Decimal(18, 2)

  notes     String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, year, month, fortnight])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, year, month])
  @@map("payroll_periods")
}

// ═══════════════════════════════════════════════════════════════
// APU — Análisis de Precios Unitarios (master library)
// ═══════════════════════════════════════════════════════════════

model ApuChapter {
  id       String  @id @default(uuid())
  tenantId String
  code     String
  name     String
  order    Int     @default(0)

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  ApuItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("apu_chapters")
}

enum ApuInputType {
  MATERIAL
  LABOR
  EQUIPMENT
}

model ApuItem {
  id         String  @id @default(uuid())
  tenantId   String
  chapterId  String
  code       String
  name       String
  unit       String  @default("GL")
  /// Factor prestacional sobre mano de obra (Colombia ≈ 1.60)
  laborFactor Decimal @default(1.6) @db.Decimal(5, 4)

  /// Computed totals (persisted for reporting)
  materialCost  Decimal @default(0) @db.Decimal(18, 4)
  laborCost     Decimal @default(0) @db.Decimal(18, 4)
  equipmentCost Decimal @default(0) @db.Decimal(18, 4)
  /// laborCost × laborFactor + materialCost + equipmentCost
  totalUnitCost Decimal @default(0) @db.Decimal(18, 4)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chapter     ApuChapter   @relation(fields: [chapterId], references: [id])
  inputs      ApuInput[]
  budgetLines BudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([chapterId])
  @@map("apu_items")
}

model ApuInput {
  id          String       @id @default(uuid())
  apuItemId   String
  type        ApuInputType
  description String
  unit        String       @default("UN")
  quantity    Decimal      @db.Decimal(18, 4)
  unitCost    Decimal      @db.Decimal(18, 4)
  total       Decimal      @db.Decimal(18, 4) // quantity × unitCost

  apuItem ApuItem @relation(fields: [apuItemId], references: [id], onDelete: Cascade)

  @@index([apuItemId])
  @@map("apu_inputs")
}

// ═══════════════════════════════════════════════════════════════
// PRESUPUESTO OFICIAL con AIU
// ═══════════════════════════════════════════════════════════════

enum BudgetStatus {
  DRAFT
  APPROVED
  SUPERSEDED // replaced by a new version
}

model OfficialBudget {
  id        String       @id @default(uuid())
  tenantId  String
  projectId String
  name      String
  version   Int          @default(1)
  status    BudgetStatus @default(DRAFT)

  /// AIU over direct cost
  adminPct  Decimal @default(0) @db.Decimal(7, 6)
  riskPct   Decimal @default(0) @db.Decimal(7, 6)
  profitPct Decimal @default(0) @db.Decimal(7, 6)

  /// Computed totals
  directCost   Decimal @default(0) @db.Decimal(18, 2)
  adminAmount  Decimal @default(0) @db.Decimal(18, 2)
  riskAmount   Decimal @default(0) @db.Decimal(18, 2)
  profitAmount Decimal @default(0) @db.Decimal(18, 2)
  aiuAmount    Decimal @default(0) @db.Decimal(18, 2)
  totalBudget  Decimal @default(0) @db.Decimal(18, 2)

  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project          Project          @relation(fields: [projectId], references: [id])
  chapters         BudgetChapter[]
  lines            BudgetLine[]
  certificates     ProjectCertificate[]
  liquidations     ProjectLiquidation[]

  @@index([tenantId])
  @@index([projectId])
  @@map("official_budgets")
}

model BudgetChapter {
  id       String @id @default(uuid())
  budgetId String
  code     String
  name     String
  order    Int    @default(0)

  /// Computed from lines
  totalCost Decimal @default(0) @db.Decimal(18, 2)

  budget OfficialBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  lines  BudgetLine[]

  @@index([budgetId])
  @@map("budget_chapters")
}

model BudgetLine {
  id         String  @id @default(uuid())
  budgetId   String
  chapterId  String
  apuItemId  String? // optional link to APU library
  code       String?
  description String
  unit       String  @default("GL")
  quantity   Decimal @db.Decimal(18, 4)
  unitCost   Decimal @db.Decimal(18, 4)
  totalCost  Decimal @db.Decimal(18, 4) // quantity × unitCost
  order      Int     @default(0)

  budget          OfficialBudget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  chapter         BudgetChapter    @relation(fields: [chapterId], references: [id])
  apuItem         ApuItem?         @relation(fields: [apuItemId], references: [id])
  certificateLines CertificateLine[]

  @@index([budgetId])
  @@index([chapterId])
  @@map("budget_lines")
}

// ═══════════════════════════════════════════════════════════════
// ACTAS DE AVANCE (Project Certificates)
// ═══════════════════════════════════════════════════════════════

enum CertificateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  VOIDED
}

model ProjectCertificate {
  id       String            @id @default(uuid())
  tenantId String
  projectId String
  budgetId  String
  number   Int
  name     String?
  certDate DateTime

  status CertificateStatus @default(DRAFT)

  /// Retention (garantía): typically 5-10% of certified amount
  retentionPct    Decimal @default(0.05) @db.Decimal(7, 6)
  /// Computed fields
  grossAmount     Decimal @default(0) @db.Decimal(18, 2) // sum of lines
  retentionAmount Decimal @default(0) @db.Decimal(18, 2)
  netAmount       Decimal @default(0) @db.Decimal(18, 2)

  /// Cumulative progress up to and including this certificate
  cumulativeAmount Decimal @default(0) @db.Decimal(18, 2)
  cumulativePct    Decimal @default(0) @db.Decimal(7, 4) // 0–100

  notes     String?
  approvedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id])
  budget  OfficialBudget @relation(fields: [budgetId], references: [id])
  lines   CertificateLine[]

  @@unique([projectId, number])
  @@index([tenantId])
  @@index([projectId])
  @@map("project_certificates")
}

model CertificateLine {
  id            String @id @default(uuid())
  certificateId String
  budgetLineId  String
  description   String
  unit          String @default("GL")

  /// Quantities
  totalQuantityBudgeted Decimal @db.Decimal(18, 4)
  previousQuantity      Decimal @default(0) @db.Decimal(18, 4)
  currentQuantity       Decimal @db.Decimal(18, 4)
  cumulativeQuantity    Decimal @db.Decimal(18, 4)

  unitCost          Decimal @db.Decimal(18, 4)
  currentAmount     Decimal @db.Decimal(18, 2)
  cumulativeAmount  Decimal @db.Decimal(18, 2)
  /// % of budgeted quantity executed cumulatively
  executedPct       Decimal @default(0) @db.Decimal(7, 4)

  certificate ProjectCertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  budgetLine  BudgetLine         @relation(fields: [budgetLineId], references: [id])

  @@index([certificateId])
  @@index([budgetLineId])
  @@map("certificate_lines")
}

// ═══════════════════════════════════════════════════════════════
// LIQUIDACIÓN FINAL
// ═══════════════════════════════════════════════════════════════

enum LiquidationStatus {
  DRAFT
  FINAL
}

enum DeductionType {
  RETENCION_GARANTIA   // Retención de garantía acumulada
  ANTICIPO             // Descuento de anticipo recibido
  MULTA                // Multas por incumplimiento
  RETENCION_FUENTE     // Retención en la fuente sobre contrato
  RETEICA              // Retención de ICA
  DESCUENTO_PRESTAMO   // Préstamos y anticipos al contratista
  OTHER
}

model ProjectLiquidation {
  id        String             @id @default(uuid())
  tenantId  String
  projectId String
  budgetId  String
  status    LiquidationStatus  @default(DRAFT)

  liquidationDate DateTime

  /// Financial summary
  contractValue     Decimal @db.Decimal(18, 2) // valor del contrato
  additionsValue    Decimal @default(0) @db.Decimal(18, 2) // adiciones
  totalContractValue Decimal @db.Decimal(18, 2) // contractValue + addiciones

  totalExecuted     Decimal @db.Decimal(18, 2) // sum of approved certificates
  totalRetained     Decimal @default(0) @db.Decimal(18, 2) // retención garantía acumulada
  totalDeductions   Decimal @default(0) @db.Decimal(18, 2) // other deductions
  netBalance        Decimal @db.Decimal(18, 2) // totalExecuted - totalRetained - totalDeductions

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project    Project              @relation(fields: [projectId], references: [id])
  budget     OfficialBudget       @relation(fields: [budgetId], references: [id])
  deductions LiquidationDeduction[]

  @@unique([projectId])
  @@index([tenantId])
  @@map("project_liquidations")
}

model LiquidationDeduction {
  id             String        @id @default(uuid())
  liquidationId  String
  type           DeductionType
  description    String
  amount         Decimal       @db.Decimal(18, 2)

  liquidation ProjectLiquidation @relation(fields: [liquidationId], references: [id], onDelete: Cascade)

  @@index([liquidationId])
  @@map("liquidation_deductions")
}

// ═══════════════════════════════════════════════════════════════
// PROVEEDORES (Vendors / Suppliers)
// ═══════════════════════════════════════════════════════════════

model Vendor {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  taxId       String?  // NIT
  email       String?
  phone       String?
  address     String?
  contactName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseInvoices PurchaseInvoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("vendors")
}

// ═══════════════════════════════════════════════════════════════
// FACTURAS DE PROVEEDOR (Accounts Payable)
// ═══════════════════════════════════════════════════════════════

enum PurchaseInvoiceStatus {
  PENDING   // Sin pagar
  PARTIAL   // Pago parcial
  PAID      // Pagado totalmente
  VOID      // Anulada
}

model PurchaseInvoice {
  id           String               @id @default(uuid())
  tenantId     String
  vendorId     String
  number       String
  status       PurchaseInvoiceStatus @default(PENDING)
  issueDate    DateTime
  dueDate      DateTime?

  subtotal     Decimal  @default(0) @db.Decimal(18, 2)
  retentionPct Decimal  @default(0) @db.Decimal(7, 6) // e.g. 0.025 = 2.5%
  retentionAmt Decimal  @default(0) @db.Decimal(18, 2)
  total        Decimal  @default(0) @db.Decimal(18, 2) // subtotal - retentionAmt
  paidAmount   Decimal  @default(0) @db.Decimal(18, 2)
  balance      Decimal  @default(0) @db.Decimal(18, 2) // total - paidAmount

  notes          String?
  journalEntryId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor       Vendor               @relation(fields: [vendorId], references: [id])
  lines        PurchaseInvoiceLine[]
  payments     VendorPayment[]
  journalEntry JournalEntry?        @relation(fields: [journalEntryId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id               String  @id @default(uuid())
  purchaseInvoiceId String
  accountId        String? // cuenta de gasto
  description      String
  quantity         Decimal @db.Decimal(18, 4)
  unitCost         Decimal @db.Decimal(18, 4)
  totalCost        Decimal @db.Decimal(18, 4)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([purchaseInvoiceId])
  @@map("purchase_invoice_lines")
}

model VendorPayment {
  id                String   @id @default(uuid())
  tenantId          String
  purchaseInvoiceId String
  amount            Decimal  @db.Decimal(18, 2)
  cashAccountId     String   // cuenta débito (caja/banco)
  paymentDate       DateTime
  reference         String?
  journalEntryId    String?  @unique
  createdAt         DateTime @default(now())

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseInvoice  PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
  journalEntry     JournalEntry?   @relation("VendorPaymentJournal", fields: [journalEntryId], references: [id])

  @@index([tenantId])
  @@index([purchaseInvoiceId])
  @@map("vendor_payments")
}

// ═══════════════════════════════════════════════════════════════
// RECIBOS DE CAJA + COMPROBANTES DE EGRESO
// ═══════════════════════════════════════════════════════════════

enum CashTransactionStatus {
  DRAFT
  POSTED
  VOIDED
}

model CashReceipt {
  id              String                @id @default(uuid())
  tenantId        String
  number          String
  status          CashTransactionStatus @default(DRAFT)
  concept         String
  thirdParty      String?  // nombre del pagador
  amount          Decimal  @db.Decimal(18, 2)
  cashAccountId   String   // cuenta destino (caja/banco — 1105/1110)
  incomeAccountId String?  // cuenta origen ingreso (si no hay factura relacionada)
  relatedInvoiceId String? // factura de venta relacionada (opcional)
  receiptDate     DateTime
  notes           String?
  journalEntryId  String?  @unique
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("cash_receipts")
}

model CashDisbursement {
  id                 String                @id @default(uuid())
  tenantId           String
  number             String
  status             CashTransactionStatus @default(DRAFT)
  concept            String
  beneficiary        String
  amount             Decimal  @db.Decimal(18, 2)
  cashAccountId      String   // cuenta crédito (caja/banco)
  expenseAccountId   String   // cuenta débito (gasto/activo)
  projectId          String?  // proyecto asociado (opcional)
  disbursementDate   DateTime
  notes              String?
  journalEntryId     String?  @unique
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("cash_disbursements")
}

// ═══════════════════════════════════════════════════════════════
// CAJA MENOR (Petty Cash) por Proyecto
// ═══════════════════════════════════════════════════════════════

enum PettyCashStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum PettyCashCategory {
  TRANSPORT
  SUPPLIES
  FOOD
  COMMUNICATION
  TOOLS
  OTHER
}

model PettyCashFund {
  id             String          @id @default(uuid())
  tenantId       String
  projectId      String?
  name           String
  responsible    String          // nombre del responsable
  cashAccountId  String          // cuenta contable asignada
  initialBalance Decimal         @db.Decimal(18, 2)
  currentBalance Decimal         @db.Decimal(18, 2)
  status         PettyCashStatus @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project?              @relation(fields: [projectId], references: [id])
  transactions PettyCashTransaction[]

  @@index([tenantId])
  @@index([tenantId, projectId])
  @@map("petty_cash_funds")
}

model PettyCashTransaction {
  id            String            @id @default(uuid())
  fundId        String
  description   String
  category      PettyCashCategory @default(OTHER)
  amount        Decimal           @db.Decimal(18, 2)
  receiptNumber String?
  transactionDate DateTime
  createdAt     DateTime          @default(now())

  fund PettyCashFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId])
  @@map("petty_cash_transactions")
}

// ═══════════════════════════════════════════════════════════════
// OBLIGACIONES TRIBUTARIAS (Taxes)
// ═══════════════════════════════════════════════════════════════

enum TaxType {
  IVA           // IVA bimestral/cuatrimestral
  RETEFUENTE    // Retención en la fuente
  RETEICA       // Retención de ICA
  RENTA         // Impuesto de renta anual
  ICA           // Industria y Comercio
  CREE          // Autorretención CREE
  GMF           // Gravamen Movimientos Financieros
}

enum TaxObligationStatus {
  PENDING
  PAID
  OVERDUE
}

model TaxObligation {
  id         String              @id @default(uuid())
  tenantId   String
  type       TaxType
  period     String              // e.g. "2025-03" or "2025-I"
  base       Decimal             @db.Decimal(18, 2)
  rate       Decimal             @db.Decimal(7, 6)
  amount     Decimal             @db.Decimal(18, 2)
  dueDate    DateTime
  status     TaxObligationStatus @default(PENDING)
  notes      String?

  // Set when paid
  paidDate       DateTime?
  paidAmount     Decimal?        @db.Decimal(18, 2)
  cashAccountId  String?
  journalEntryId String?         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("tax_obligations")
}

// ═══════════════════════════════════════════════════════════════
// BILLING — Suscripción $59 USD / 8 usuarios / 30 días
// ═══════════════════════════════════════════════════════════════

enum BillingStatus {
  PENDING  // Generada, pendiente de pago
  PAID     // Pagada
  OVERDUE  // Vencida sin pagar
  VOID     // Anulada (plan free, trial, etc.)
}

model BillingInvoice {
  id          String        @id @default(uuid())
  tenantId    String
  /// Número de factura de suscripción (SUBS-001, SUBS-002…)
  number      String
  status      BillingStatus @default(PENDING)

  /// Período que cubre esta factura
  periodStart DateTime
  periodEnd   DateTime

  /// Usuarios activos al momento de generar la factura
  activeUsers Int
  /// Bloques de 8 usuarios (ceil(activeUsers / 8))
  units       Int
  /// Precio por bloque (USD)
  unitPriceUsd Decimal @default(59) @db.Decimal(10, 2)
  /// Total en USD = units × unitPriceUsd
  totalUsd    Decimal  @db.Decimal(10, 2)

  dueDate     DateTime
  paidAt      DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status, dueDate])
  @@map("billing_invoices")
}
