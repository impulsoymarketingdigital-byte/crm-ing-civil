# ─────────────────────────────────────────────────────────────────────────────
# ERP Ingeniería Civil — Variables de entorno
# Copiar a .env y completar los valores
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (el puerto 5434 es el usado en docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5434/netsuite_clone?schema=public"

# JWT — usar un string largo aleatorio en producción
# Generar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="8h"

# Anthropic API key — para extracción OCR de facturas con IA
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
# Opcional: Modelo de Claude a utilizar (por defecto: claude-3-5-sonnet-20241022)
# AI_MODEL="claude-3-5-sonnet-20241022"

# Servidor
PORT=3000
NODE_ENV="development"

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
